#!/usr/bin/env bash
# Upgrade /crg-debug from prose orchestration to the deterministic JS Workflow.
# Plugins cannot package workflows, so this copies the bundled workflow + its
# methodology into ~/.claude/workflows/. The methodology path is resolved at
# runtime — the /crg-debug skill passes it as args.methodologyPath, no baking.
# Idempotent; safe to re-run after a plugin update.
set -euo pipefail

plugin_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
dest="$HOME/.claude/workflows"
methodology="$dest/crg-debug.methodology.md"

mkdir -p "$dest"
cp "$plugin_root/skills/crg-debug/methodology.md" "$methodology"
cp "$plugin_root/lib/issue-ref.mjs" "$dest/crg-debug.issue-ref.mjs"
cp "$plugin_root/lib/ledger-slice.mjs" "$dest/crg-debug.ledger-slice.mjs"
cp "$plugin_root/lib/farm-db.mjs" "$dest/crg-debug.farm-db.mjs"
cp "$plugin_root/workflows/crg-debug.js" "$dest/crg-debug.js"
cp "$plugin_root/skills/crg-farm/methodology.md" "$dest/crg-debug.farm-methodology.md"
cp "$plugin_root/workflows/crg-debug.farm-bypass.js" "$dest/crg-debug.farm-bypass.js"
cp "$plugin_root/workflows/crg-build.js" "$dest/crg-build.js"
cp "$plugin_root/skills/crg-build/methodology.md" "$dest/crg-build.methodology.md"
cp "$plugin_root/lib/build-profile.mjs" "$dest/crg-build.profile.mjs"
cp "$plugin_root/workflows/crg-integrations.js" "$dest/crg-integrations.js"
cp "$plugin_root/skills/crg-integrations/methodology.md" "$dest/crg-integrations.methodology.md"
cp "$plugin_root/lib/integrations-profile.mjs" "$dest/crg-integrations.profile.mjs"

# crg-agentsmd (AGENTS.md farming). The workflow is stamped with the plugin commit at install
# time and logs it on launch, so a stale install is visible in the first log line of any run.
# Lib copies get their relative imports rewritten to the installed filenames.
stamp="$(git -C "$plugin_root" rev-parse --short HEAD 2>/dev/null || echo unknown)-$(date +%Y%m%d)"
sed "s/dev-repo/${stamp}/" "$plugin_root/workflows/crg-agentsmd.js" > "$dest/crg-agentsmd.js"
cp "$plugin_root/skills/crg-agentsmd/methodology.md" "$dest/crg-agentsmd.methodology.md"
sed "s|'./issue-ref.mjs'|'./crg-debug.issue-ref.mjs'|" "$plugin_root/lib/corpus.mjs" > "$dest/crg-agentsmd.corpus.mjs"
sed "s|'./corpus.mjs'|'./crg-agentsmd.corpus.mjs'|" "$plugin_root/lib/agentsmd-score.mjs" > "$dest/crg-agentsmd.score.mjs"
sed -e "s|'./issue-ref.mjs'|'./crg-debug.issue-ref.mjs'|" -e "s|'./corpus.mjs'|'./crg-agentsmd.corpus.mjs'|" "$plugin_root/lib/agentsmd-ab.mjs" > "$dest/crg-agentsmd.ab.mjs"

echo "Installed deterministic crg-debug workflow:"
echo "  $dest/crg-debug.js"
echo "  $methodology"
echo "  $dest/crg-debug.issue-ref.mjs"
echo "  $dest/crg-debug.ledger-slice.mjs      (/crg-farm)"
echo "  $dest/crg-debug.farm-db.mjs           (/crg-farm)"
echo "  $dest/crg-debug.farm-methodology.md   (/crg-farm --auto-bypass harness)"
echo "  $dest/crg-debug.farm-bypass.js        (/crg-farm --auto-bypass harness)"
echo "  $dest/crg-build.js                    (/crg-build)"
echo "  $dest/crg-build.methodology.md        (/crg-build)"
echo "  $dest/crg-build.profile.mjs           (/crg-build)"
echo "  $dest/crg-integrations.js             (/crg-integrations)"
echo "  $dest/crg-integrations.methodology.md (/crg-integrations)"
echo "  $dest/crg-integrations.profile.mjs    (/crg-integrations)"
echo "  $dest/crg-agentsmd.js                 (/crg-agentsmd, build ${stamp})"
echo "  $dest/crg-agentsmd.methodology.md     (/crg-agentsmd)"
echo "  $dest/crg-agentsmd.corpus.mjs         (/crg-agentsmd)"
echo "  $dest/crg-agentsmd.score.mjs          (/crg-agentsmd)"
echo "  $dest/crg-agentsmd.ab.mjs             (/crg-agentsmd --ab)"
echo "Run /crg-debug — it now prefers the Workflow (use --prose to force prose mode)."
echo "/crg-farm --auto-bypass now prefers this harness too (use --prose to force prose mode)."
echo "/crg-build now prefers its Workflow too (use --prose to force prose mode)."
echo "/crg-integrations now prefers its Workflow too (use --prose to force prose mode)."
